# ---- CritiFlix API environment ----
# Local MongoDB:   mongodb://127.0.0.1:27017/critiflix
# MongoDB Atlas:   mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/critiflix
MONGODB_URI=mongodb://127.0.0.1:27017/critiflix

PORT=4000
NODE_ENV=development

# Auth secrets — generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=10

# Seeded demo accounts share this password (dev convenience only)
SEED_PASSWORD=critiflix123

# ---- Paystack (optional) ----
# Leave blank to run subscription/cashout flows in simulated mode.
# Get keys at https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:4000/api/me/subscribe/callback

# Admin bootstrap (used by `npm run seed`)
ADMIN_NAME=CritiFlix Admin
ADMIN_EMAIL=admin@critiflix.app
ADMIN_PASSWORD=
